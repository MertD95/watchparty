{
  "name": "watchparty",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node dev-reload.mjs",
    "gen:actions": "node tools/gen-action-contract.mjs",
    "gen:icons": "node tools/generate-icons.mjs",
    "test": "npm run test:fast",
    "test:fast": "npm run syntax && npm run test:routing && npm run test:landing && npm run test:sync-engine && npm run test:crypto",
    "test:integration": "npm run test:sidepanel",
    "test:full": "npm run test:fast && npm run test:integration && npm run test:browser",
    "test:routing": "node extension/test/routing.mjs",
    "test:browser": "node extension/test/run-with-local-server.mjs extension/test/e2e-browser.mjs",
    "test:sidepanel": "node extension/test/run-with-local-server.mjs extension/test/sidepanel.mjs",
    "test:crypto": "node extension/test/crypto.mjs",
    "test:landing": "node extension/test/landing.mjs",
    "test:sync-engine": "node extension/test/sync-engine.mjs",
    "debug:invalid-room-key": "node tools/debug-invalid-room-key.mjs",
    "debug:production-smoke": "node tools/production-smoke.mjs",
    "debug:browser:raw": "node extension/test/e2e-browser.mjs",
    "debug:sidepanel:raw": "node extension/test/sidepanel.mjs",
    "syntax": "node scripts/syntax-check.mjs"
  },
  "devDependencies": {
    "chokidar": "^4.0.0",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "ws": "^8.20.0"
  }
}
